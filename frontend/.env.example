# Vite dev proxy target — where /api and /child-profiles are forwarded.
# Local BE (Docker): http://localhost:5001  (see ../backend/README.md)
# Staging/Prod: ask BE team for the base URL
VITE_API_PROXY_TARGET=http://localhost:5001

# Production build only — full API base URL (no trailing slash).
# Leave empty in dev to use relative paths + Vite proxy above.
# VITE_API_URL=https://api.greenlens.com

# Force in-browser mocks (skip all network calls)
# VITE_USE_MOCK=true

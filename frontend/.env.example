# Vite dev proxy target — where /api and /child-profiles are forwarded.
# Local BE (Docker): http://localhost:5001  (see ../backend/README.md)
# Staging/Prod: ask BE team for the base URL
VITE_API_PROXY_TARGET=http://localhost:5001

# Production build only — full API base URL (no trailing slash).
# Leave empty in dev to use relative paths + Vite proxy above.
# VITE_API_URL=https://api.greenlens.com

# Force in-browser mocks (character creation, AI camera, quiz — no backend needed)
# VITE_USE_MOCK=true

# Supertonic TTS (on-device in browser only — no Web Speech fallback)
# VITE_USE_SUPERTONIC_TTS=true
# Voice preset (bundled in public/supertonic/voice_styles/): F1-F5 (female), M1-M5 (male)
# VITE_SUPERTONIC_VOICE=F5
# Optional: host all assets yourself — VITE_SUPERTONIC_ASSETS_BASE=/supertonic

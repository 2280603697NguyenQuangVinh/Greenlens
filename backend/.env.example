# Local development with real DynamoDB
USE_IN_MEMORY_CHILD_PROFILES=false
USE_IN_MEMORY_AUTH=true
ALLOW_DEV_AUTH=true
CHILD_PROFILES_TABLE_NAME=GreenLens-ChildProfiles
DYNAMODB_CHILD_PROFILES_TABLE=GreenLens-ChildProfiles

# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=ap-southeast-1

# AWS Cognito
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_APP_CLIENT_ID=your_app_client_id_here
COGNITO_APP_CLIENT_SECRET=
AI_CAMERA_BUCKET_NAME=your_ai_camera_bucket_name_here
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=180
AI_CAMERA_GUIDANCE_FALLBACK_ENABLED=true
AI_CAMERA_SKIP_BEDROCK_WHEN_FALLBACK_ENABLED=true
AI_CAMERA_USAGE_LIMITER_ENABLED=true
AI_CAMERA_USAGE_TABLE_NAME=GreenLens-AiUsage
AI_CAMERA_PER_MINUTE_LIMIT=3
AI_CAMERA_DAILY_LIMIT=20
QUIZ_BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
QUIZ_BEDROCK_MAX_TOKENS=700
QUIZ_BEDROCK_TIMEOUT_SECONDS=10
QUIZ_SESSIONS_TABLE_NAME=GreenLens-QuizSessions
QUIZ_FALLBACK_TABLE_NAME=GreenLens-QuizFallbacks
QUIZ_DEFAULT_AGE=8
MINI_GAME_RESULTS_TABLE_NAME=GreenLens-MiniGameResults
MINI_GAME_ITEMS_TABLE_NAME=GreenLens-MiniGameItems
MINI_GAME_ASSET_BUCKET_NAME=your_ai_camera_bucket_name_here
MINI_GAME_ASSET_BASE_URL=

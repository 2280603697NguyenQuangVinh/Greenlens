# Local development with real DynamoDB
USE_IN_MEMORY_CHILD_PROFILES=false
USE_IN_MEMORY_AUTH=true
ALLOW_DEV_AUTH=true
CHILD_PROFILES_TABLE_NAME=GreenLens-ChildProfiles
DYNAMODB_CHILD_PROFILES_TABLE=GreenLens-ChildProfiles

# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=ap-southeast-1

# AWS Cognito
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_APP_CLIENT_ID=your_app_client_id_here
COGNITO_APP_CLIENT_SECRET=
AI_CAMERA_BUCKET_NAME=your_ai_camera_bucket_name_here
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

{
  "expo": {
    "name": "GreenLens Kids",
    "slug": "greenlens-kids",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "backgroundColor": "#f0fdf4",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.greenlens.kids"
    },
    "android": {
      "package": "com.greenlens.kids",
      "adaptiveIcon": {
        "backgroundColor": "#22c55e"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
